generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        Int        @id @default(autoincrement())
  nom       String
  prenom    String
  telephone String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  commandes Commande[]
}

model Categorie {
  id        Int          @id @default(autoincrement())
  libelle   String       @unique
  image     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  produits  Produit[]
  kits      KitProduit[]
}

model Produit {
  id            Int            @id @default(autoincrement())
  nom           String
  description   String?
  prix          Float
  image         String?
  quantite      Int
  categorieId   Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  commandeItems CommandeItem[]
  categorie     Categorie      @relation(fields: [categorieId], references: [id])
}

model KitProduit {
  id          Int     @id @default(autoincrement())
  nom         String
  description String?
  prix        Float
  quantite    Int
  categorieId Int // ← nouveau champ obligatoire
  type        TypeKit  @default(COMPLET)   // ← nouveau champ


  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  image         String?
  commandeItems CommandeItem[]
  details       KitProduitDetail[]
  categorie     Categorie          @relation(fields: [categorieId], references: [id]) // ← nouvelle relation
}

model KitProduitDetail {
  id          Int        @id @default(autoincrement())
  kitId       Int
  nom         String
  description String?
  prix        Float
  quantite    Int
  image       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  kit         KitProduit @relation(fields: [kitId], references: [id], onDelete: Cascade)
}


model Commande {
  id             Int            @id @default(autoincrement())
  clientId       Int
  status         CommandeStatus @default(EN_ATTENTE)
  total          Float
  montantPaye    Float          @default(0)
  statutPaiement StatutPaiement @default(NON_PAYEE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  client         Client         @relation(fields: [clientId], references: [id])
  details        CommandeItem[]
  paiements      Paiement[]
}

model CommandeItem {
  id         Int         @id @default(autoincrement())
  commandeId Int
  produitId  Int?
  kitId      Int?
  quantite   Int
  prix       Float
  commande   Commande    @relation(fields: [commandeId], references: [id])
  kit        KitProduit? @relation(fields: [kitId], references: [id])
  produit    Produit?    @relation(fields: [produitId], references: [id])
}


model Paiement {
  id         Int      @id @default(autoincrement())
  commandeId Int
  montant    Float
  methode    String?  // "Espèces", "Orange Money", "Wave", etc.
  note       String?
  createdAt  DateTime @default(now())
  commande   Commande @relation(fields: [commandeId], references: [id])
}

enum Role {
  SUPERADMIN
  ADMIN
}

enum CommandeStatus {
  EN_ATTENTE
  LIVREE
}
enum StatutPaiement {
  NON_PAYEE
  PARTIELLEMENT_PAYEE
  PAYEE
}

enum TypeKit {
  COMPLET
  DEMI
  QUART
}